{
    "workspace.ignoreDir": [
        "xmake/templates",
        "core"
    ],
    "workspace.library": [
        "xmake/templates",
        "core"
    ],
    "diagnostics.libraryFiles": "Disable",
    "diagnostics.disable": [
        "unknown-symbol",
        "exp-in-action",
        "undefined-global",
        "undefined-field",
        "need-check-nil",
        "lowercase-global",
        "inject-field",
        "undefined-global",
        "undefined-field",
        "iter-variable-reassign",
        "call-non-callable",
        "unnecessary-assert",
        "unnecessary-if",
        "param-type-mismatch",
        "assign-type-mismatch",
        "global-in-non-module",
        "access-invisible"
    ]
}
